// Production schema (PostgreSQL)
// For local SQLite dev fallback see: prisma/schema.sqlite.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  UNDERGRAD
  GRAD
  PHD
  ALUMNI
  FACULTY
  STAFF
  OTHER
}

enum DietaryPreference {
  VEG
  VEGAN
  NO_PREFERENCE
  OTHER
}

model Event {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  startDateTime DateTime
  endDateTime   DateTime
  location      String
  tags          String[]
  speakerName   String?
  speakerBio    String?
  coverImage    String?
  gallery       String[]
  description   String
  agenda        String?
  faq           String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rsvps         RSVP[]

  @@index([startDateTime])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   @default("Beginner")
  summary     String?
  contentMd   String?
  externalUrl String?
  youtubeUrl  String?
  downloads   String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Program {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  summary   String
  detailsMd String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RSVP {
  id                String            @id @default(cuid())
  eventId           String
  fullName          String
  email             String
  phone             String?
  studentStatus     StudentStatus
  dietaryPreference DietaryPreference @default(VEG)
  notes             String?
  consent           Boolean
  createdAt         DateTime          @default(now())

  event             Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
}
